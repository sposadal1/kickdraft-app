# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (NUNCA usar NEXT_PUBLIC_ — solo en rutas server-side).
# Necesario para operaciones de admin que bypasean RLS (ej. insertar rachas_otorgadas).
# Configurar en Vercel: Settings → Environment Variables → SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google AdSense
# Establece el Publisher ID con el prefijo completo "ca-pub-".
# Cuando esta variable NO está definida (ej. en desarrollo local) AdSense no se carga.
# En producción (Vercel): Settings → Environment Variables → NEXT_PUBLIC_ADSENSE_CLIENT
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_FOOTER_SLOT=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_CLASSIFICATION_SLOT=XXXXXXXXXX

# Versión de la app (opcional, usado por /api/health)
# NEXT_PUBLIC_APP_VERSION=1.0.0

# API-Football (solo para Supabase Edge Functions — NO agregar al .env.local real)
# Configurar únicamente como secret en Supabase con:
#   supabase secrets set API_FOOTBALL_KEY=your_api_football_key_here
# API_FOOTBALL_KEY=your_api_football_key_here
