# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google AdSense (opcional — solo añadir cuando tengas cuenta aprobada)
# NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_FOOTER_SLOT=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_CLASSIFICATION_SLOT=XXXXXXXXXX

# Versión de la app (opcional, usado por /api/health)
# NEXT_PUBLIC_APP_VERSION=1.0.0

# API-Football (solo para Supabase Edge Functions — NO agregar al .env.local real)
# Configurar únicamente como secret en Supabase con:
#   supabase secrets set API_FOOTBALL_KEY=your_api_football_key_here
# API_FOOTBALL_KEY=your_api_football_key_here
